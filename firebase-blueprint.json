{
  "entities": {
    "DashboardStats": {
      "title": "DashboardStats",
      "description": "Geopolitical dashboard statistics generated by AI to save tokens",
      "type": "object",
      "properties": {
        "executiveBriefing": {
          "type": "string",
          "description": "Thai language high-level executive briefing"
        },
        "geopoliticalTrends": {
          "type": "array",
          "description": "List of current global trends"
        },
        "sourceBiasAnalysis": {
          "type": "array",
          "description": "List of source biases detected"
        },
        "threatMatrix": {
          "type": "array",
          "description": "Regional threat heatmap coordinates and scores"
        },
        "criticalEntities": {
          "type": "array",
          "description": "List of extracted people, entities or coalitions"
        },
        "generatedAt": {
          "type": "string",
          "description": "ISO timestamp of extraction"
        }
      },
      "required": [
        "executiveBriefing",
        "geopoliticalTrends",
        "sourceBiasAnalysis",
        "threatMatrix",
        "criticalEntities",
        "generatedAt"
      ]
    },
    "ArticleReport": {
      "title": "ArticleReport",
      "description": "Deep tactical OSINT analysis report for a single news article to prevent duplicate API generation",
      "type": "object",
      "properties": {
        "articleId": {
          "type": "string",
          "description": "The unique article identifier"
        },
        "title": {
          "type": "string",
          "description": "Original article title"
        },
        "source": {
          "type": "string",
          "description": "Name of news publisher"
        },
        "link": {
          "type": "string",
          "description": "URL link to the article"
        },
        "pubDate": {
          "type": "string",
          "description": "Original publication date"
        },
        "creator": {
          "type": "string",
          "description": "Author of the article"
        },
        "contentSnippet": {
          "type": "string",
          "description": "Cleaned article summary text used as input"
        },
        "report": {
          "type": "object",
          "description": "The deep intelligence assessment generated by Gemini"
        },
        "generatedAt": {
          "type": "string",
          "description": "ISO timestamp of extraction"
        }
      },
      "required": [
        "articleId",
        "title",
        "source",
        "link",
        "pubDate",
        "creator",
        "contentSnippet",
        "report",
        "generatedAt"
      ]
    }
  },
  "firestore": {
    "/dashboard/{documentId}": {
      "schema": "DashboardStats",
      "description": "Stores the central live dashboard summaries and trends dynamically to save shared token costs"
    },
    "/articleReports/{articleId}": {
      "schema": "ArticleReport",
      "description": "Persistently caches military-grade OSINT assessments for each parsed headline"
    }
  }
}
